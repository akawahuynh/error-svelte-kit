{
  "name": "@repo/ui",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "svelte-kit sync && svelte-package --watch",
    "build": "svelte-kit sync && svelte-package",
    "lint": "eslint .",
    "check-types": "svelte-check --tsconfig ./tsconfig.json",
    "glob": "node script/glob.ts"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "src",
    "!src/**/*.test.*",
    "!src/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./utils": {
      "default": "./dist/utils.js",
      "types": "./dist/utils.d.ts"
    },
    "./components": {
      "default": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./hooks": {
      "default": "./dist/hooks/index.js",
      "types": "./dist/hooks/index.d.ts"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@internationalized/date": "catalog:",
    "@lucide/svelte": "catalog:",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/table-core": "catalog:",
    "@types/node": "catalog:",
    "bits-ui": "catalog:",
    "clsx": "catalog:",
    "embla-carousel-svelte": "catalog:",
    "eslint": "^9.39.4",
    "formsnap": "catalog:",
    "layerchart": "catalog:",
    "mode-watcher": "catalog:",
    "paneforge": "catalog:",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.5",
    "svelte-sonner": "catalog:",
    "sveltekit-superforms": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwind-variants": "catalog:",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "catalog:",
    "typescript": "5.9.2",
    "vaul-svelte": "catalog:",
    "vite": "^6.4.1"
  },
  "dependencies": {
    "glob": "catalog:"
  }
}